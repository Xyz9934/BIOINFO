#:import dp kivy.metrics.dp

MDScreen:
    MDNavigationLayout:
        MDScreenManager:
            MDScreen:
                MDFloatLayout:
                    md_bg_color: 0.03, 0.05, 0.10, 1

                    MDTopAppBar:
                        id: top_bar
                        title: "Bioinformatics Explorer"
                        pos_hint: {"top": 1}
                        elevation: 0
                        md_bg_color: 0.04, 0.06, 0.11, 1
                        left_action_items: [["menu", lambda x: app.toggle_drawer()]]
                        right_action_items: [["history", lambda x: app.show_history_action()], ["content-save", lambda x: app.show_saved_sequences_action()], ["bookmark-multiple", lambda x: app.show_bookmarks_action()]]

                    BoxLayout:
                        orientation: "vertical"
                        spacing: dp(14)
                        padding: dp(16), dp(84), dp(16), dp(16)

                        ScrollView:
                            do_scroll_x: False
                            bar_width: dp(6)

                            BoxLayout:
                                orientation: "vertical"
                                spacing: dp(14)
                                size_hint_y: None
                                height: self.minimum_height

                                MDCard:
                                    orientation: "horizontal" if self.width > dp(1100) else "vertical"
                                    padding: dp(16)
                                    spacing: dp(16)
                                    radius: [22, 22, 22, 22]
                                    md_bg_color: 0.04, 0.06, 0.11, 1
                                    size_hint_y: None
                                    height: dp(610)

                                    MDCard:
                                        orientation: "vertical"
                                        padding: dp(16)
                                        spacing: dp(14)
                                        radius: [20, 20, 20, 20]
                                        md_bg_color: 0.06, 0.09, 0.15, 1

                                        MDLabel:
                                            text: "DNA / FASTA Sequence Analysis"
                                            bold: True
                                            font_style: "H6"
                                            adaptive_height: True

                                        MDTextField:
                                            id: sequence_input
                                            multiline: True
                                            text: ">sample_1\nATGGCCATTGTAATGGGCCGCTGAAAGGGTGCCCGATAG"
                                            mode: "rectangle"
                                            hint_text: "Paste DNA / FASTA Sequence"
                                            size_hint_y: None
                                            height: dp(150)

                                        BoxLayout:
                                            orientation: "vertical"
                                            spacing: dp(10)
                                            size_hint_y: None
                                            height: dp(162)

                                            MDRaisedButton:
                                                text: "Analyze Sequence"
                                                md_bg_color: 0.45, 0.25, 0.92, 1
                                                size_hint_x: None
                                                width: dp(220)
                                                pos_hint: {"center_x": .5}
                                                on_release: app.analyze_sequence_action()

                                            MDRaisedButton:
                                                text: "Upload FASTA File"
                                                md_bg_color: 0.20, 0.55, 0.92, 1
                                                size_hint_x: None
                                                width: dp(220)
                                                pos_hint: {"center_x": .5}
                                                on_release: app.upload_fasta_action()

                                            MDRaisedButton:
                                                text: "Run Alignment"
                                                md_bg_color: 0.18, 0.68, 0.40, 1
                                                size_hint_x: None
                                                width: dp(220)
                                                pos_hint: {"center_x": .5}
                                                on_release: app.run_alignment_action()

                                        MDCard:
                                            orientation: "vertical"
                                            padding: dp(12)
                                            radius: [16, 16, 16, 16]
                                            md_bg_color: 0.07, 0.10, 0.17, 1
                                            size_hint_y: None
                                            height: dp(118)

                                            MDLabel:
                                                text: "Sequence Visualization"
                                                bold: True
                                                adaptive_height: True

                                            ScrollView:
                                                do_scroll_x: False
                                                MDLabel:
                                                    id: sequence_visualization
                                                    text: "No sequence loaded."
                                                    markup: True
                                                    adaptive_height: True
                                                    text_size: self.width, None

                                        MDLabel:
                                            id: sequence_title
                                            text: "Ready to analyze."
                                            theme_text_color: "Hint"
                                            adaptive_height: True

                                        MDCard:
                                            orientation: "vertical"
                                            padding: dp(16)
                                            spacing: dp(14)
                                            radius: [20, 20, 20, 20]
                                            md_bg_color: 0.06, 0.09, 0.15, 1
                                            size_hint_x: 0.42 if self.parent and self.parent.width > dp(1100) else 1
                                            size_hint_y: None
                                            height: dp(610) if self.parent and self.parent.width > dp(1100) else dp(360)

                                            MDLabel:
                                                text: "Analysis Results"
                                                bold: True
                                                font_style: "H6"
                                                adaptive_height: True

                                        GridLayout:
                                            cols: 3
                                            spacing: dp(10)
                                            size_hint_y: None
                                            height: dp(118)

                                            MetricCard:
                                                id: length_card
                                                title: "Sequence Length"
                                                value: "0 bp"
                                                value_color: 0.33, 0.70, 1, 1

                                            MetricCard:
                                                id: gc_card
                                                title: "GC Content"
                                                value: "0.00%"
                                                value_color: 0.25, 0.89, 0.54, 1

                                            MetricCard:
                                                id: weight_card
                                                title: "Molecular Weight"
                                                value: "0.00"
                                                value_color: 0.63, 0.44, 1, 1

                                        GridLayout:
                                            cols: 4 if self.width > dp(700) else 2
                                            spacing: dp(10)
                                            size_hint_y: None
                                            height: dp(236) if self.cols == 2 else dp(118)

                                            MetricCard:
                                                id: a_card
                                                title: "Adenine (A)"
                                                value: "0 (0.0%)"
                                                value_color: 0.33, 0.70, 1, 1
                                            MetricCard:
                                                id: t_card
                                                title: "Thymine (T)"
                                                value: "0 (0.0%)"
                                                value_color: 1, 0.82, 0.29, 1
                                            MetricCard:
                                                id: g_card
                                                title: "Guanine (G)"
                                                value: "0 (0.0%)"
                                                value_color: 0.25, 0.89, 0.54, 1
                                            MetricCard:
                                                id: c_card
                                                title: "Cytosine (C)"
                                                value: "0 (0.0%)"
                                                value_color: 0.50, 0.48, 1, 1

                                        BoxLayout:
                                            spacing: dp(10)
                                            size_hint_y: None
                                            height: dp(120)

                                            InfoCard:
                                                id: reverse_card
                                                title: "Reverse Complement"
                                                body: "-"

                                            InfoCard:
                                                id: protein_card
                                                title: "Protein Translation"
                                                body: "-"

                                MDCard:
                                    orientation: "vertical"
                                    padding: dp(16)
                                    spacing: dp(14)
                                    radius: [22, 22, 22, 22]
                                    md_bg_color: 0.04, 0.06, 0.11, 1
                                    size_hint_y: None
                                    height: dp(1040)

                                    MDLabel:
                                        text: "Disease / Gene Search"
                                        bold: True
                                        font_style: "H6"
                                        adaptive_height: True

                                    BoxLayout:
                                        orientation: "vertical"
                                        spacing: dp(10)
                                        size_hint_y: None
                                        height: dp(220)

                                        MDTextField:
                                            id: search_input
                                            hint_text: "Search disease or gene"
                                            text: "BRCA1"
                                            mode: "rectangle"

                                        BoxLayout:
                                            spacing: dp(10)
                                            size_hint_y: None
                                            height: dp(116)
                                            orientation: "horizontal" if self.width > dp(900) else "vertical"

                                            MDRaisedButton:
                                                text: "Search"
                                                md_bg_color: 0.45, 0.25, 0.92, 1
                                                on_release: app.search_gene_action()

                                            MDFlatButton:
                                                text: "Clear"
                                                on_release: app.clear_search_action()

                                            MDRaisedButton:
                                                text: "Save Sequence"
                                                md_bg_color: 0.20, 0.55, 0.92, 1
                                                on_release: app.save_sequence_action()

                                            MDRaisedButton:
                                                text: "Bookmark Gene"
                                                md_bg_color: 0.18, 0.68, 0.40, 1
                                                on_release: app.bookmark_gene_action()

                                    BoxLayout:
                                        spacing: dp(14)
                                        size_hint_y: None
                                        height: dp(260)

                                        MDCard:
                                            orientation: "vertical"
                                            padding: dp(16)
                                            spacing: dp(10)
                                            radius: [20, 20, 20, 20]
                                            md_bg_color: 0.06, 0.09, 0.15, 1

                                            MDLabel:
                                                id: local_gene_title
                                                text: "Disease / Gene Information"
                                                bold: True
                                                adaptive_height: True

                                            ScrollView:
                                                do_scroll_x: False
                                                MDLabel:
                                                    id: local_gene_body
                                                    text: "Search to view local disease-gene information."
                                                    adaptive_height: True
                                                    text_size: self.width, None

                                        MDCard:
                                            orientation: "vertical"
                                            padding: dp(16)
                                            spacing: dp(10)
                                            radius: [20, 20, 20, 20]
                                            md_bg_color: 0.06, 0.09, 0.15, 1

                                            MDLabel:
                                                id: ncbi_gene_title
                                                text: "NCBI Gene Summary"
                                                bold: True
                                                adaptive_height: True

                                            ScrollView:
                                                do_scroll_x: False
                                                MDLabel:
                                                    id: ncbi_gene_body
                                                    text: "Search to view live NCBI gene summaries."
                                                    adaptive_height: True
                                                    text_size: self.width, None

                                    BoxLayout:
                                        spacing: dp(14)
                                        orientation: "horizontal" if self.width > dp(1000) else "vertical"

                                        MDCard:
                                            orientation: "vertical"
                                            padding: dp(16)
                                            spacing: dp(10)
                                            radius: [20, 20, 20, 20]
                                            md_bg_color: 0.06, 0.09, 0.15, 1
                                            size_hint_x: 0.34 if self.parent and self.parent.width > dp(1000) else 1
                                            size_hint_y: None
                                            height: dp(320) if self.parent and self.parent.width > dp(1000) else dp(260)

                                            MDLabel:
                                                text: "Nucleotide % Pie Chart"
                                                bold: True
                                                adaptive_height: True

                                            FitImage:
                                                id: pie_chart
                                                source: "assets/nucleotide_pie.png"
                                                radius: [18, 18, 18, 18]

                                        MDCard:
                                            orientation: "vertical"
                                            padding: dp(16)
                                            spacing: dp(10)
                                            radius: [20, 20, 20, 20]
                                            md_bg_color: 0.06, 0.09, 0.15, 1
                                            size_hint_y: None
                                            height: dp(320) if self.parent and self.parent.width > dp(1000) else dp(420)

                                            MDLabel:
                                                text: "Related Diseases"
                                                bold: True
                                                adaptive_height: True

                                            ScrollView:
                                                do_scroll_x: False
                                                MDBoxLayout:
                                                    orientation: "vertical"
                                                    adaptive_height: True
                                                    spacing: dp(10)

                                                    MDLabel:
                                                        id: related_diseases
                                                        text: "-"
                                                        adaptive_height: True
                                                        text_size: self.width, None

                                                    MDSeparator:

                                                    MDLabel:
                                                        text: "Protein Information"
                                                        bold: True
                                                        adaptive_height: True

                                                    MDLabel:
                                                        id: protein_info
                                                        text: "-"
                                                        adaptive_height: True
                                                        text_size: self.width, None

                                                    MDSeparator:

                                                    MDLabel:
                                                        text: "External Links"
                                                        bold: True
                                                        adaptive_height: True

                                                    MDLabel:
                                                        id: external_links
                                                        text: "-"
                                                        adaptive_height: True
                                                        text_size: self.width, None

                                    MDCard:
                                        orientation: "vertical"
                                        padding: dp(16)
                                        spacing: dp(10)
                                        radius: [20, 20, 20, 20]
                                        md_bg_color: 0.06, 0.09, 0.15, 1
                                        size_hint_y: None
                                        height: dp(300)

                                        MDLabel:
                                            id: alignment_title
                                            text: "Alignment Viewer"
                                            bold: True
                                            adaptive_height: True

                                        MDLabel:
                                            id: alignment_stats
                                            text: "Identity: - | Score: -"
                                            theme_text_color: "Hint"
                                            adaptive_height: True

                                        ScrollView:
                                            do_scroll_x: True
                                            do_scroll_y: True
                                            bar_width: dp(5)
                                            MDLabel:
                                                id: alignment_body
                                                text: "Load a multi-sequence FASTA file with 2 or more sequences to run alignment."
                                                markup: True
                                                adaptive_height: True
                                                width: max(self.texture_size[0], dp(900))
                                                size_hint_x: None
                                                text_size: None, None

                                    MDCard:
                                        orientation: "vertical"
                                        padding: dp(16)
                                        spacing: dp(12)
                                        radius: [20, 20, 20, 20]
                                        md_bg_color: 0.06, 0.09, 0.15, 1
                                        size_hint_y: None
                                        height: dp(560)

                                        MDLabel:
                                            text: "Disease Symptoms, Precautions, and Treatment"
                                            bold: True
                                            adaptive_height: True

                                        MDLabel:
                                            id: disease_type_label
                                            text: "Disease Type: Search a disease to load enriched clinical notes"
                                            theme_text_color: "Hint"
                                            adaptive_height: True

                                        BoxLayout:
                                            spacing: dp(12)
                                            orientation: "horizontal" if self.width > dp(1000) else "vertical"
                                            
                                            MDBoxLayout:
                                                orientation: "vertical"
                                                spacing: dp(12)
                                                size_hint_x: 0.72 if self.parent and self.parent.width > dp(1000) else 1
                                                size_hint_y: None
                                                height: dp(520) if self.parent and self.parent.width > dp(1000) else dp(420)

                                                BoxLayout:
                                                    spacing: dp(12)

                                                    MDCard:
                                                        orientation: "vertical"
                                                        padding: dp(14)
                                                        spacing: dp(8)
                                                        radius: [18, 18, 18, 18]
                                                        md_bg_color: 0.07, 0.10, 0.17, 1

                                                        MDLabel:
                                                            text: "Symptoms"
                                                            bold: True
                                                            adaptive_height: True

                                                        ScrollView:
                                                            do_scroll_x: False
                                                            MDLabel:
                                                                id: symptoms_body
                                                                text: "Search a disease to view detailed symptoms."
                                                                adaptive_height: True
                                                                text_size: self.width, None

                                                    MDCard:
                                                        orientation: "vertical"
                                                        padding: dp(14)
                                                        spacing: dp(8)
                                                        radius: [18, 18, 18, 18]
                                                        md_bg_color: 0.07, 0.10, 0.17, 1

                                                        MDLabel:
                                                            text: "Precautions"
                                                            bold: True
                                                            adaptive_height: True

                                                        ScrollView:
                                                            do_scroll_x: False
                                                            MDLabel:
                                                                id: precautions_body
                                                                text: "Search a disease to view precautions."
                                                                adaptive_height: True
                                                                text_size: self.width, None

                                                    MDCard:
                                                        orientation: "vertical"
                                                        padding: dp(14)
                                                        spacing: dp(8)
                                                        radius: [18, 18, 18, 18]
                                                        md_bg_color: 0.07, 0.10, 0.17, 1

                                                        MDLabel:
                                                            text: "Treatment / Cure"
                                                            bold: True
                                                            adaptive_height: True

                                                        ScrollView:
                                                            do_scroll_x: False
                                                            MDLabel:
                                                                id: treatment_body
                                                                text: "Search a disease to view treatment or care details."
                                                                adaptive_height: True
                                                                text_size: self.width, None

                                            MDCard:
                                                orientation: "vertical"
                                                padding: dp(14)
                                                spacing: dp(8)
                                                radius: [18, 18, 18, 18]
                                                md_bg_color: 0.07, 0.10, 0.17, 1
                                                size_hint_x: 0.28 if self.parent and self.parent.width > dp(1000) else 1
                                                size_hint_y: None
                                                height: dp(520) if self.parent and self.parent.width > dp(1000) else dp(220)

                                                MDLabel:
                                                    text: "AI Explanation"
                                                    bold: True
                                                    adaptive_height: True

                                                ScrollView:
                                                    do_scroll_x: False
                                                    MDLabel:
                                                        id: ai_explanation_body
                                                        text: "Search a disease to generate a simple explanation panel."
                                                        adaptive_height: True
                                                        text_size: self.width, None

                        MDCard:
                            radius: [16, 16, 16, 16]
                            md_bg_color: 0.08, 0.10, 0.16, 1
                            size_hint_y: None
                            height: dp(40)
                            padding: dp(12), 0

                            MDLabel:
                                id: status_label
                                text: "Ready"
                                theme_text_color: "Custom"
                                text_color: 0.35, 0.88, 0.50, 1

        MDNavigationDrawer:
            id: nav_drawer
            radius: [0, 16, 16, 0]
            md_bg_color: 0.05, 0.07, 0.12, 1

            BoxLayout:
                orientation: "vertical"
                padding: dp(16)
                spacing: dp(12)

                MDLabel:
                    text: "BioExplorer"
                    font_style: "H5"
                    bold: True
                    adaptive_height: True

                MDLabel:
                    text: "Backend-first KivyMD bioinformatics workspace"
                    theme_text_color: "Hint"
                    adaptive_height: True

                MDSeparator:

                OneLineIconListItem:
                    text: "Analyze Sequence"
                    on_release:
                        nav_drawer.set_state("close")
                    IconLeftWidget:
                        icon: "dna"

                OneLineIconListItem:
                    text: "View History"
                    on_release:
                        app.show_history_action()
                        nav_drawer.set_state("close")
                    IconLeftWidget:
                        icon: "history"

                OneLineIconListItem:
                    text: "Saved Sequences"
                    on_release:
                        app.show_saved_sequences_action()
                        nav_drawer.set_state("close")
                    IconLeftWidget:
                        icon: "content-save"

                OneLineIconListItem:
                    text: "Bookmarked Genes"
                    on_release:
                        app.show_bookmarks_action()
                        nav_drawer.set_state("close")
                    IconLeftWidget:
                        icon: "bookmark"
