#:import dp kivy.metrics.dp

<MetricCard>:
    orientation: "vertical"
    padding: dp(14)
    spacing: dp(6)
    radius: [24, 24, 24, 24]
    md_bg_color: 0.11, 0.15, 0.24, 0.92
    size_hint_y: None
    height: dp(118)
    title: ""
    value: ""
    value_color: 1, 1, 1, 1
    MDLabel:
        text: root.title
        theme_text_color: "Custom"
        text_color: 0.72, 0.80, 0.95, 1
        font_style: "Body1"
        adaptive_height: True
    MDLabel:
        text: root.value
        theme_text_color: "Custom"
        text_color: root.value_color
        font_style: "H6"
        bold: True
        adaptive_height: True

<InfoCard>:
    orientation: "vertical"
    padding: dp(14)
    spacing: dp(10)
    radius: [24, 24, 24, 24]
    md_bg_color: 0.10, 0.14, 0.22, 0.92
    title: ""
    body: ""
    MDLabel:
        text: root.title
        theme_text_color: "Custom"
        text_color: 0.72, 0.80, 0.95, 1
        bold: True
        adaptive_height: True
    ScrollView:
        do_scroll_x: False
        bar_width: dp(4)
        MDLabel:
            text: root.body
            theme_text_color: "Custom"
            text_color: 0.95, 0.97, 1, 1
            adaptive_height: True
            text_size: self.width, None
